{
  "expo": {
    "name": "AFI Docs",
    "slug": "afi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#14213D",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo-afi.png",
      "resizeMode": "contain",
      "backgroundColor": "#14213D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sn.afi.docs"
    },
    "android": {
      "package": "sn.afi.docs",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14213D"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
