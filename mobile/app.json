{
  "expo": {
    "name": "AFI Docs",
    "slug": "afi-mobile",
    "version": "1.0.5",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#14213D",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo-afi.png",
      "resizeMode": "contain",
      "backgroundColor": "#14213D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sn.afi.docs"
    },
    "android": {
      "package": "sn.afi.docs",
      "versionCode": 7,
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14213D"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#C0392B"
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "a58c92ab-d88b-4518-a5b8-2a736da66c48"
      }
    },
    "owner": "pauldaryll"
  }
}
