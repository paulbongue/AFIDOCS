# ===========================================================================
#  CONFIGURATION DE PRODUCTION — AFI-DOCS (VPS)
#  Copier ce fichier en ".env" sur le serveur, puis :
#    php artisan key:generate
#  Remplacer les valeurs entre < > par les tiennes.
# ===========================================================================

APP_NAME="AFI-DOCS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://<afidocs.duckdns.org>

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# ---------------------------------------------------------------------------
# Base de donnees : MySQL 8 (sur le VPS). Utiliser un compte DEDIE (pas root),
# avec un mot de passe FORT.
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=afi_plateforme
DB_USERNAME=afi_user
DB_PASSWORD=<MOT_DE_PASSE_FORT_BDD>

# ---------------------------------------------------------------------------
# Sessions / cache / file d'attente
# ---------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=public

# En production : on ne journalise pas tout en debug.
LOG_CHANNEL=stack
LOG_LEVEL=warning

# ---------------------------------------------------------------------------
# Sanctum / CORS : n'autoriser QUE ton domaine (le frontend et l'API sont
# servis depuis le meme VPS).
# ---------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=<afidocs.duckdns.org>
FRONTEND_URL=https://<afidocs.duckdns.org>

# ---------------------------------------------------------------------------
# Email (notifications). Utiliser un vrai SMTP (offre gratuite Brevo/SendGrid).
# Tant que tu n'en as pas, garde MAIL_MAILER=log (les emails iront dans les logs).
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=<identifiant_smtp>
MAIL_PASSWORD=<cle_smtp>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@afi.sn"
MAIL_FROM_NAME="AFI-DOCS"
