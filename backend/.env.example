APP_NAME="Plateforme AFI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# ---------------------------------------------------------------------------
# Base de donnees : MySQL 8 (via XAMPP en local)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=afi_plateforme
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Drivers simplifies (fichier) pour eviter des tables supplementaires
# ---------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=public

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Sanctum / CORS : autoriser le frontend et l'app mobile (Expo)
# En dev mobile, l'app envoie un token Bearer : pas besoin de cookies.
# ---------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Email (notifications). Par defaut "log" : les emails sont ecrits dans
# storage/logs/laravel.log (aucun SMTP requis pour tester).
# Pour de vrais envois, passe MAIL_MAILER=smtp et renseigne le serveur SMTP
# (ex : Mailtrap en test, Gmail/SendGrid/Brevo en production).
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@afi.sn"
MAIL_FROM_NAME="AFI-DOCS"
